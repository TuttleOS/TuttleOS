# Tuttle OS — environment variables (example only)
# Copy to .env / .env.local / Vercel project settings. NEVER commit real secrets.
# Related: docs/SECURITY_PROTOCOLS.md §8–9, docs/COMPLIANCE_GATES.md, docs/DATABASE_SETUP.md

# --- Database (Phase 0 — schema apply via scripts/apply_schema.sh) ---
# Supabase: Project Settings → Database → URI (URL-encode special chars in password)
# Example direct:  postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres
# Example pooler:  postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# --- Public (safe for browser via NEXT_PUBLIC_*) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=local
# local | staging | production — never point local at production DB with real PHI

# Feature flags (strings "true" / "false")
# Documents = Storage upload on Case Manager matters (sql/16). Keep AI false.
NEXT_PUBLIC_FEATURE_DOCUMENTS=false
NEXT_PUBLIC_FEATURE_DOCUMENT_AI=false
NEXT_PUBLIC_FEATURE_CALENDAR_SYNC=false

# --- Server-only (Vercel / Node — NEVER NEXT_PUBLIC_) ---
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Used only in trusted server routes / workers. Never ship to the client bundle.

# Optional: server-side Supabase if different from public URL (usually same project)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# --- Observability (PHI scrubbing REQUIRED before enabling in production) ---
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ENVIRONMENT=local
# NEXT_PUBLIC_SENTRY_DSN=

# --- Phase 8 documents / AI (disabled until BAAs + owner gate) ---
# DOCUMENT_AI_ENABLED=false
# OCR_PROVIDER=tesseract
# OCR_CLOUD_PROVIDER=
# OCR_CLOUD_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_HIPAA_ENABLED=false

# --- Phase 9 calendar (org DPA required) ---
# MICROSOFT_GRAPH_CLIENT_ID=
# MICROSOFT_GRAPH_CLIENT_SECRET=
# MICROSOFT_GRAPH_TENANT_ID=
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=

# --- Phase 10 CasePeer migration (owner machine only; CSVs never in git) ---
# CASEPEER_CSV_DIR=/path/to/Dropbox/0 Tuttle OS/CasePeer exported reports
# CASEPEER_EXPECTED_CASES=770
# CASEPEER_CLIENTS_CSV=ClientsReport-8.csv
# CASEPEER_OPEN_CSV=OpenCasesReport-4.csv
# CASEPEER_NOTES_CSV=NotesReport.csv

# --- Integrations (BAAs/DPAs as required) ---
# RINGCENTRAL_CLIENT_ID=
# RINGCENTRAL_CLIENT_SECRET=
# RINGCENTRAL_JWT=

# --- Ops ---
# LOG_LEVEL=info
# PHI_LOGGING=false
# Enforce: application code must refuse to log request bodies when PHI_LOGGING is false

# --- Playwright e2e (web/) ---
# E2E_EMAIL=intake@tuttlelawfirm.com
# E2E_PASSWORD=
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
